# ── Database ──────────────────────────────────────
POSTGRES_USER=financeai
POSTGRES_PASSWORD=changeme
POSTGRES_DB=financeai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Auth ──────────────────────────────────────────
# Генерируй командой: openssl rand -hex 32
JWT_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id

# ── AI ────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── RevenueCat ─────────────────────────────────────
# Shared secret used to authenticate RevenueCat webhook events.
# Set the same value in RevenueCat → Integrations → Webhooks → Authorization header:
#   Bearer <REVENUECAT_WEBHOOK_SECRET>
REVENUECAT_WEBHOOK_SECRET=changeme_generate_with_openssl_rand_hex_32

# ── AI budget guard ────────────────────────────────
# Soft daily cap in USD for Claude API spend across all users. When exceeded,
# /ai/command returns 503 and a Telegram alert is fired. Set 0 to disable.
AI_DAILY_BUDGET_USD=5.0

# ── App ───────────────────────────────────────────
APP_ENV=development      # development | production
APP_VERSION=0.1.0
